# Server Configuration
PORT=3000
ELECTRON=true

# Twilio configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
AUTHORIZED_NUMBERS=+1234567890,+0987654321

# Remote Control configuration
ENABLE_REMOTE_CONTROL=true
REMOTE_CONTROL_PORT=8900

# Perplexity AI Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=llama-3-8b-instruct

# Claude AI Configuration
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-7-sonnet-20250219-v1:0
CLAUDE_API_VERSION=2023-06-01
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.2
CLAUDE_CODE_TIMEOUT=30000
USE_CLAUDE_CLI=true
CLAUDE_ALLOWED_COMMANDS=ls,git status,git log,npm test,node,find,grep
CLAUDE_TERMINAL_MODE=clipboard  # 'clipboard' or 'direct'
ALLOW_AUTOMATED_COMMANDS=false  # Set to true to enable fully automated non-interactive mode

# Project Configuration for Claude
GAANA_PROJECT_PATH=/path/to/your/gaana/project
DEFAULT_PROJECT_NAME=brainClassify
DEFAULT_PROJECT_PATH=/path/to/your/brainClassify/project
BRAINCLASSIFY_CWD=/path/to/your/brainClassify/project

# Default AI Provider (claude or perplexity)
DEFAULT_PROVIDER=claude

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gaana
MONGODB_DB_NAME=gaana