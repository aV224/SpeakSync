{
  "name": "gaana-desktop",
  "version": "1.0.0",
  "description": "Desktop application with Twilio integration for voice calls and AI desktop control",
  "main": "electron.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "remote": "node controllers/remoteController.js",
    "electron": "electron .",
    "desktop": "node server.js & electron .",
    "package": "node build.js",
    "package:mac": "node build.js --mac",
    "package:win": "node build.js --win",
    "postinstall": "electron-builder install-app-deps",
    "db:migrate": "node backend/src/utils/dbMigrationScript.js",
    "setup-claude": "node scripts/setup-claude-env.js",
    "test-claude": "node test-claude.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.8.4",
    "axios-oauth-1.0a": "^0.4.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^4.4.8",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "jimp": "^0.22.10",
    "mongoose": "^8.13.1",
    "multer": "^1.4.5-lts.2",
    "rimraf": "^6.0.1",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^27.1.2",
    "electron-builder": "^24.6.4",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.gaana.desktop",
    "productName": "Gaana AI Assistant",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/.{idea,git,cache,github,vscode}",
      "!**/{.DS_Store,.git,.gitignore,.npmignore}"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
